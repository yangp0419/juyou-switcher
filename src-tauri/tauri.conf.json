{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "聚游助手",
  "version": "1.0.1",
  "identifier": "com.juyouswitcher.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3030",
    "beforeDevCommand": "pnpm run dev:renderer",
    "beforeBuildCommand": "pnpm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "titleBarStyle": "Overlay",
        "width": 1000,
        "height": 650,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https: http:",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "template": "wix/per-user-main.wxs",
        "language": "zh-CN"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "juyouswitcher"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyMEExMUJDRDhGQkRFNTAKUldSUTN2dll2QkVLUWs5b1Vlek9TenliRmZrcXBlbXR1elIzbi9UaTduMEFvMFQ0TFkzQ2VNR0YK",
      "endpoints": [
        "https://github.com/yangp0419/juyou-switcher/releases/latest/download/latest.json"
      ]
    }
  }
}
