# Backend bind address
BIND_ADDR=127.0.0.1:8010

# Direct OSS/CDN URLs or signed-URL gateway targets.
DOWNLOAD_MAC_URL=https://your-oss-domain.com/juyou-switcher/latest/juyou-switcher-mac.dmg
DOWNLOAD_WINDOWS_URL=https://your-oss-domain.com/juyou-switcher/latest/juyou-switcher-windows.msi
DOWNLOAD_LINUX_URL=https://your-oss-domain.com/juyou-switcher/latest/juyou-switcher-linux.AppImage

# Basic per-IP, per-platform in-memory rate limits.
DOWNLOAD_LIMIT_PER_MINUTE=8
DOWNLOAD_LIMIT_PER_HOUR=60
